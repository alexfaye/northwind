config {
    type: "table",
    name: "stg_products",
    tags: ["sales_overview","sales_agents","product_inventory"],
    description: "This is the stage db for products."
}

select * except(supplier_ids), 
    cast(supplier_ids as int64) as supplier_id,
    current_timestamp as ingestion_timestamp
from ${ref("products")}
where supplier_ids not like '%;%'